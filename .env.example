AUTH_SECRET=
NEXT_PUBLIC_API_BASE=

# Dev login bypass — set to 'true' to enable dev-only login in production while backend is under development
NEXT_PUBLIC_ALLOW_DEV_LOGIN=false

# API request/response logging — auto-on in dev. Set to 'true' to force logs in production (tokens/passwords are redacted).
NEXT_PUBLIC_API_DEBUG=false

# Stripe redirect targets — consumed by the BACKEND when creating Checkout /
# Billing Portal sessions. They point at these frontend routes (already built):
#   STRIPE_SUCCESS_URL       -> /payment/success   (Checkout success)
#   STRIPE_CANCEL_URL        -> /payment/cancel    (Checkout cancel)
#   STRIPE_PORTAL_RETURN_URL -> /account           (Billing Portal return)
# e.g. https://dev.smartliferewards.com.au/payment/success